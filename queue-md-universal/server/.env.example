# =========================================
# QueueMD — .env.example
# =========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to git!
# =========================================

# 1. SERVER CONFIGURATION
PORT=5000
NODE_ENV=development

# 2. DATABASE (MongoDB Atlas)
# Generate new credentials from: https://cloud.mongodb.com/
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# 3. AUTHENTICATION & SECURITY
# Generate a 64-char secret: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_EXPIRE=2h
JWT_REFRESH_EXPIRE=30d
# 🔒 Use 12 rounds for production security
BCRYPT_SALT_ROUNDS=12

# 4. FRONTEND URL (CORS)
CLIENT_URL=http://localhost:5173

# 5. REDIS (Caching & Notifications)
# Get from: https://upstash.com/
REDIS_URL=rediss://default:<password>@<host>:<port>

# 6. PAYMENT GATEWAY (Razorpay)
# Get from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_XXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXXXXXX

# 7. PROJECT CONFIG
SUPPORTED_FACILITY_TYPES=clinic,hospital,pathlab,dental,physio,other
DEFAULT_FACILITY_TYPE=clinic

# 8. LOGGING
LOG_LEVEL=info

# 9. CLOUDINARY (Image Upload)
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
